{
  "name": "orbiter",
  "version": "0.1.0",
  "description": "Orbiter — Desktop UI for Claude Code & Codex",
  "author": {
    "name": "Peter Alexeev Dauwalter",
    "email": "alexeev.dauwalter@41t.org"
  },
  "contributors": [
    {
      "name": "Lucas Couto",
      "url": "https://github.com/lcoutodemos"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexeev-dauwalter/orbiter.git"
  },
  "bugs": {
    "url": "https://github.com/alexeev-dauwalter/orbiter/issues"
  },
  "homepage": "https://github.com/lcoutodemos/orbiter#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build --mode production && electron-builder --mac --dir",
    "dist:linux": "electron-vite build --mode production && electron-builder --linux",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-dev-icon.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "^12.35.1",
    "node-pty": "^1.1.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.orbiter.app",
    "productName": "Orbiter",
    "executableName": "orbiter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Orbiter uses your microphone to transcribe voice input locally with Whisper."
      }
    },
    "linux": {
      "icon": "resources/icons",
      "target": ["AppImage", "rpm"],
      "category": "Development",
      "desktop": {
        "entry": {
          "Name": "Orbiter",
          "Comment": "Desktop UI for Claude Code & Codex",
          "StartupWMClass": "orbiter"
        }
      }
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
